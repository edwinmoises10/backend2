# ── Servidor ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/auth_system

# ── Sesiones ─────────────────────────────────────────────
SESSION_SECRET=cambia_este_valor_por_uno_seguro_de_al_menos_32_chars
SESSION_NAME=sid
SESSION_MAX_AGE_MS=86400000

# ── Google OAuth 2.0 ─────────────────────────────────────
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
FRONTEND_SUCCESS_URL=http://localhost:3000/

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=otro_secreto_distinto_al_de_sesion_min_32_chars
JWT_EXPIRES_IN=1h
JWT_COOKIE_NAME=token

# ── Seguridad ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
